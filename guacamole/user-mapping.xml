<user-mapping>
    <authorize username="lmstudio" password="lmstudio">
        <connection name="LM Studio Shared Desktop">
            <protocol>vnc</protocol>
            <param name="hostname">lmstudio</param>
            <param name="port">5900</param>
            <param name="password">lmstudio</param>
            <param name="autoretry">3</param>
            <param name="disable-display-resize">false</param>
            <param name="color-depth">24</param>
            <param name="cursor">remote</param>
            <param name="disable-copy">false</param>
            <param name="disable-paste">false</param>
            <param name="clipboard-encoding">UTF-8</param>
        </connection>
    </authorize>
</user-mapping>
