# 桌面环境是否使用 GPU 渲染 (true/false)
# 若为 false，则强制使用软件渲染，可降低 GPU 占用
ENABLE_GPU_RENDERING=true

# 是否在每次启动时强制重新下载 LM Studio AppImage (true/false)
# 默认 false，即仅当检测到新版本时才下载
FORCE_UPDATE=false

# 是否跳过远程版本检查（网络不稳定时建议 true，可减少启动等待）
# 当ForCE_UPDATE=false时，和SKIP_REMOTE_VERSION_CHECK=true会导致永远不更新，除非手动删除缓存或改环境变量。
SKIP_REMOTE_VERSION_CHECK=false

# 远程版本检查超时时间（秒）
UPDATE_CHECK_MAX_TIME=8

# LM Studio 下载参数（新机网络不稳定时可适当调大）
# LM_STUDIO_DOWNLOAD_URL 为空时，自动使用官方 latest 地址
LM_STUDIO_DOWNLOAD_URL=
LM_STUDIO_DOWNLOAD_RETRIES=3
LM_STUDIO_DOWNLOAD_TIMEOUT=30

# 自动安装 GPU 运行时后端（cuda/vulkan）并选择首选后端
AUTO_INSTALL_GPU_BACKENDS=false

# 运行时引擎家族（默认 llama.cpp）
RUNTIME_ENGINE_FAMILY=llama.cpp

# 首选后端（建议 cuda）
PREFERRED_GPU_BACKEND=cuda

# 回退后端（保留回退策略；当 cuda 选择失败时自动尝试 vulkan）
FALLBACK_GPU_BACKEND=vulkan

# 自动后端安装等待 lms CLI 的最长秒数
LMS_BACKEND_SETUP_TIMEOUT=240

# 后端自动选择重试次数（过大容易造成启动期反复请求）
LMS_BACKEND_SELECT_RETRIES=1

# 后端自动配置完成标记（存在则后续启动跳过自动配置）
LMS_BACKEND_AUTOCONFIG_STAMP=/root/.cache/lm-studio/.internal/.backend-autoconfig-done

# LM Studio 进程守护：窗口被关闭时自动拉起
LM_ENSURE_RUNNING=true
LM_RESTART_INTERVAL=2
LM_ENSURE_WINDOW=true
LM_WINDOW_MISSING_TICKS=3
LM_WINDOW_GRACE_SECONDS=20
LM_WATCHDOG_DEBUG=false

# 覆盖容器可见的 NVIDIA 能力；建议保留 display，降低 runtime 误判
NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics,display,video

# LM Studio API 对外暴露端口（宿主机端口 -> guacweb:1234 -> lmstudio:1234，默认 1234）
# 警告：不要在 LM Studio UI 里修改 API 端口。容器内服务固定监听 1234，改 UI 会导致访问异常。
LMS_API_PORT=1234

# Guacamole Web 入口端口（nginx 在容器内/宿主机均监听该端口，浏览器访问 http://<host-ip>:8888 ）
GUAC_WEB_PORT=8888

# guacweb nginx 的 HTTPS 开关（false=http, true=https）
GUAC_WEB_HTTPS_ENABLE=true
# 证书有效性校验开关：
# true  -> 必须使用 cert 目录中的证书，并校验证书/私钥文件格式与配对；失败则容器退出
# false -> 若证书不可用则自动生成 localhost 自签证书
GUAC_WEB_HTTPS_VERIFY_CERT=false
# 当启用 HTTPS 时使用的证书文件名（放在 ./cert 目录）
GUAC_WEB_CERT_FILE=localhost.crt
GUAC_WEB_KEY_FILE=localhost.key

# Guacamole 登录账号
GUAC_USERNAME=lmstudio
GUAC_PASSWORD=lmstudio


# 单连接允许动态跟随浏览器分辨率，多连接时由容器策略锁定为 1080p
GUAC_DISABLE_DISPLAY_RESIZE=false
GUAC_COLOR_DEPTH=24
GUAC_CURSOR=remote
# 剪贴板编码默认使用 UTF-8，提升中文复制粘贴兼容性。
GUAC_DISABLE_COPY=false
GUAC_DISABLE_PASTE=false
GUAC_CLIPBOARD_ENCODING=UTF-8
# 伪键盘注入：当剪贴板变化时，把文本直接键入当前焦点窗口（绕过应用粘贴行为）
CLIPBOARD_FAKE_KEYBOARD_ENABLE=false
CLIPBOARD_MAX_TYPE_CHARS=8192
# 独立 HTTP 剪贴板桥（由 guacweb 通过 /__clipboard_bridge 转发），推荐的方案，兼容性最好，性能较高。
CLIPBOARD_BRIDGE_ENABLE=true

# Guacamole 登录默认用户见 guacamole/user-mapping.xml
# 默认: lmstudio / lmstudio

# 显示参数（分辨率越高，带宽和编码压力越大）
# 桌面语言设置：ENG（默认）或 CN-ZH
DESKTOP_LANGUAGE=ENG

DISPLAY_NUM=99
SCREEN_RESOLUTION=1920x1080
SCREEN_DEPTH=24

# 分辨率策略：1 人动态，多于 1 人强制 1080p
ENABLE_MULTI_CLIENT_1080P_LOCK=true
MULTI_CLIENT_RESOLUTION=1920x1080
RESOLUTION_MONITOR_INTERVAL=2

# 单连接动态分辨率：从 Guacamole 发起的请求中提取目标尺寸（可用 hint 兜底）
ENABLE_SINGLE_CLIENT_DYNAMIC_RESOLUTION=true
SINGLE_CLIENT_RESOLUTION_HINT=

# Xvfb 最大画布（需大于单连接可能请求的分辨率）
XVFB_MAX_RESOLUTION=4096x2160

# 是否自动用 CLI 加载模型
AUTO_LOAD_MODEL=false

# 启动时清理损坏后端缓存（建议保持 true）
# 启动时清理损坏后端缓存（GPU 后端依赖该缓存，默认 false 以避免每次重下）
CLEAN_LM_VENDOR_CACHE=false